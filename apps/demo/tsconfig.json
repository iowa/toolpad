{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/toolpad/core": ["../../packages/toolpad/core"],
      "@/toolpad/core/*": ["../../packages/toolpad/core/*"],
      "@/toolpad/node": ["../../packages/toolpad/node"],
      "@/toolpad/node/*": ["../../packages/toolpad/node/*"],
      "@/toolpad/utils": ["../../packages/toolpad/utils"],
      "@/toolpad/utils/*": ["../../packages/toolpad/utils/*"]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
