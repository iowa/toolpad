{
  "name": "@iowas/toolpad",
  "version": "1.0.12",
  "license": "MIT",
  "repository": "https://github.com/iowa/toolpad",
  "description": "Custom mui-toolpad",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./swiss": {
      "types": "./dist/swiss.d.ts",
      "import": "./dist/swiss.mjs",
      "require": "./dist/swiss.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepack": "pnpm build",
    "test": "vitest",
    "format": "pretty-quick",
    "format:check": "prettier --check src",
    "format:fix": "prettier --check --write src",
    "prepare": "husky",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "upgrade-dependencies": "ncu -u"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,md}": "pnpm run format"
  },
  "dependencies": {
    "invariant": "2.2.4",
    "lodash": "^4.18.1",
    "path-to-regexp": "8.4.2",
    "prop-types": "15.8.1",
    "react-is": "^19.2.5"
  },
  "peerDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/utils": "^9.0.0",
    "@mui/x-data-grid": "^8.28.2",
    "@mui/x-date-pickers": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "drizzle-orm": "1.0.0-beta.20",
    "drizzle-zod": "^0.8.3",
    "jsonwebtoken": "^9.0.3",
    "material-ui-popup-state": "^5.3.7",
    "next": "^16.2.3",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/utils": "^9.0.0",
    "@mui/x-data-grid": "^9.0.1",
    "@mui/x-date-pickers": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@types/invariant": "^2.2.37",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "drizzle-kit": "1.0.0-beta.20",
    "drizzle-orm": "1.0.0-beta.20",
    "drizzle-zod": "^0.8.3",
    "husky": "^9.1.7",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "material-ui-popup-state": "^5.3.7",
    "next": "^16.2.3",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "postcss": "^8.5.9",
    "prettier": "3.8.2",
    "pretty-quick": "^4.2.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "mui",
    "toolpad",
    "internal tools",
    "crud",
    "admin",
    "dashboard"
  ],
  "author": "Peter Kudela",
  "packageManager": "pnpm@10.33.0"
}
