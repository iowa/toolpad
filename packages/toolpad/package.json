{
  "name": "@iowas/toolpad",
  "version": "1.0.20",
  "license": "MIT",
  "repository": "https://github.com/iowa/toolpad",
  "description": "Custom mui-toolpad",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "ncu": "ncu -u"
  },
  "dependencies": {
    "invariant": "2.2.4",
    "lodash": "^4.18.1",
    "path-to-regexp": "8.4.2",
    "prop-types": "15.8.1",
    "react-is": "^19.2.5"
  },
  "peerDependencies": {
    "@emotion/cache": "^11",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^9",
    "@mui/material": "^9",
    "@mui/material-nextjs": "^9",
    "@mui/utils": "^9",
    "@mui/x-data-grid": "^9",
    "@mui/x-date-pickers": "^9",
    "@tanstack/react-query": "^5.100.6",
    "dayjs": "^1",
    "drizzle-orm": "^1.0.0-beta",
    "next": "^16",
    "pg": "^8",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7",
    "jsonwebtoken": "^9",
    "zod": "^4"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.100.6",
    "@types/invariant": "^2.2.37",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "mui",
    "toolpad",
    "internal tools",
    "crud",
    "admin",
    "dashboard"
  ],
  "author": "Peter Kudela"
}
